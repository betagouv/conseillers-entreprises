/# locals: (collections_count:)

%ul.fr-sidemenu__list.monitoring-menu
  - collections_count.each do |name, count|
    - label = t(name, scope: [:monitoring, :antennes, :titles])
    - url = polymorphic_path([:monitoring, :antennes], collection: name)
    - title = t(name, scope: [:monitoring, :antennes, :instructions])
    = menu_link_with_count(count, url, class: "item collection-#{name}", title: title) do
      = label
      %span{ 'aria-hidden': true, class: "fr-ml-1v #{t(name, scope: 'monitoring.scopes.icon')}" }
